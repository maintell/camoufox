+    aFontName.AssignLiteral(u"-apple-system");
+    aFontStyle = mDefaultFontStyle;
+    return true;
+  }
+  if (sSpoofedOS == SpoofedOS::Win) {
+    aFontName.AssignLiteral(u"Segoe UI");
+    aFontStyle = mDefaultFontStyle;
+    return true;
+  }
+  // Linux / iPhone / unknown: fall through to upstream behavior.
+
