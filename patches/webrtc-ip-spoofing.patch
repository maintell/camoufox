+void PeerConnectionImpl::MaybeFabricateSrflxCandidate() {
+  if (!ShouldSpoofCandidateIP() || mSurfacedPublicCandidate) {
+    return;
+  }
+
+  auto ipv4Opt = MaskConfig::GetString("webrtc:ipv4");
